<script>
document.addEventListener("DOMContentLoaded", async function () {
  // Check if MemberStack is loaded
  if (!window.MemberStack) {
    console.error("MemberStack script is not initialized. Please check your setup.");
    return;
  }

  try {
    // Fetch current member data
    const member = await MemberStack.onReady;
    const memberData = member?.member;
    console.log("Fetched Member Data:", memberData);

    if (memberData) {
      // Display Member Data in Webflow
      document.querySelectorAll("[data-ms-content]").forEach((element) => {
        const key = element.getAttribute("data-ms-content");
        element.textContent = memberData[key] || "Data not available";
      });
    } else {
      console.error("No member is currently logged in.");
    }
  } catch (error) {
    console.error("Error fetching MemberStack data:", error);
  }
});


</script>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // Helper function to check if an element is visible
  const isElementVisible = (element) => {
    return element &&
      window.getComputedStyle(element).display !== 'none' &&
      !element.classList.contains('w-condition-invisible');
  };

  // Select all elements with the 'cancel-form' class
  const cancelForms = document.querySelectorAll('.cancel-form');

  cancelForms.forEach((cancelForm) => {
    // Find the nearest parent containing the cancel form
    const parent = cancelForm.closest('.purchase-details_button-wrapper');
    if (!parent) return;

    // Query the cancelled, refunded, and cancelled_without divs
    const cancelledDiv = parent.querySelector('.cancelled');
    const refundedDiv = parent.querySelector('.refunded');
    const cancelledWithoutDiv = parent.querySelector('.cancelled_without');

    // Skip if none of the relevant elements are found
    if (!cancelledDiv && !refundedDiv && !cancelledWithoutDiv) {
      console.warn('Relevant elements not found for:', cancelForm);
      return;
    }

    // Check visibility of the elements
    const isCancelledVisible = isElementVisible(cancelledDiv);
    const isRefundedVisible = isElementVisible(refundedDiv);
    const isCancelledWithoutVisible = isElementVisible(cancelledWithoutDiv);

    // Update the cancel form visibility based on the conditions
    if (isCancelledVisible || isRefundedVisible || isCancelledWithoutVisible) {
      // Hide the cancel form if any of the conditions are met
      cancelForm.classList.remove('block');
      cancelForm.classList.add('hide');
    } else {
      // Show the cancel form otherwise
      cancelForm.classList.remove('hide');
      cancelForm.classList.add('block');
    }

    // Debugging logs for visibility status
    const debug = false; // Set to true for debugging
    if (debug) {
      console.log('Cancel Form:', cancelForm);
      console.log('Cancelled Visible:', isCancelledVisible);
      console.log('Refunded Visible:', isRefundedVisible);
      console.log('Cancelled Without Visible:', isCancelledWithoutVisible);
    }
  });
});

</script>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // Select all elements with the 'cancel-form' class
  const cancelForms = document.querySelectorAll('.cancel-form');

  cancelForms.forEach((cancelForm) => {
    const parent = cancelForm.closest('.purchase-details_button-wrapper');
    if (!parent) return;

    const bookingTypeElement = parent.querySelector('.booking-type');
    if (!bookingTypeElement) return;

    const bookingTypeText = bookingTypeElement.textContent.trim();
    if (bookingTypeText === 'Admin booked') {
      cancelForm.className = 'cancel-form w-form hide'; // Set the exact class as requested
    }
  });
});

</script>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const verifyButton = document.getElementById("verify-id");
  const contactPinField = document.getElementById("Contact-Pin");
  const form = document.getElementById("wf-form-Membership-verification");

  verifyButton.addEventListener("click", async (event) => {
    event.preventDefault();

    // Retrieve and parse the _ms-mem object from localStorage
    const msMem = localStorage.getItem("_ms-mem");
    let email;

    try {
      const msMemParsed = JSON.parse(msMem);
      email = msMemParsed?.auth?.email; // Safely access nested email property
    } catch (e) {
      console.error("Error parsing _ms-mem from localStorage:", e);
    }

    if (!email) {
      alert("No verified email found in local storage. Please log in again.");
      return;
    }

    const companyId = contactPinField ? contactPinField.value.trim() : "";
    if (!companyId) {
      alert("Please enter your Company ID.");
      return;
    }

    try {
      verifyButton.disabled = true;
      verifyButton.textContent = "Verifying...";

      const response = await fetch("https://member-api-9nkw.onrender.com/update-company-id", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, companyId }),
      });

      const responseText = await response.text();
      try {
        const result = JSON.parse(responseText); // Attempt to parse JSON
        if (response.ok) {
          window.location.href = "https://biaw-stage-api.webflow.io/member-confirmation";
        } else {
          alert(result.error || "Verification failed. Please try again.");
        }
      } catch (e) {
        console.error("Server returned a non-JSON response:", responseText);
        alert("An unexpected error occurred. Please contact support.");
      }
    } catch (error) {
      console.error("Error verifying Company ID:", error);
      alert("An unexpected error occurred. Please try again.");
    } finally {
      verifyButton.disabled = false;
      verifyButton.textContent = "Verify";
    }
  });
});
</script>

